# Backend environment template.  Copy to `.env` for local docker-compose,
# or paste into Fly.io secrets (`fly secrets set ...`) for production.

# ── Frontend origin (CORS) ────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app

# ── Object storage for model weights + raw trajectories ───────────────
# Cloudflare R2 example.  Leave MODELS_BUCKET unset to use on-disk files.
MODELS_BUCKET=engine-twin-models
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Postgres for simulation history + user auth ───────────────────────
# Neon-style URL works as-is; the backend rewrites the driver suffix.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── JWT signing key (MUST be long random in production) ───────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=please-generate-a-long-random-string
