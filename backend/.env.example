# Backend environment template.  Copy to `.env` for local docker-compose,
# or paste into Fly.io secrets (`fly secrets set ...`) for production.

# ── Frontend origin (CORS) ────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app

# ── Object storage for model weights + raw trajectories ───────────────
# AWS S3:  set MODELS_BUCKET + AWS_REGION + creds.  Leave S3_ENDPOINT_URL empty.
# Cloudflare R2 / MinIO:  also set S3_ENDPOINT_URL to the S3-compatible endpoint.
MODELS_BUCKET=your-bucket-name
S3_ENDPOINT_URL=
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Postgres for simulation history + user auth ───────────────────────
# Supabase: Project Settings → Database → URI tab → Direct connection (port 5432).
# The backend rewrites postgres:// → postgresql+asyncpg:// automatically.
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ── JWT signing key (MUST be long random in production) ───────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=please-generate-a-long-random-string
